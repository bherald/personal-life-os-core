PLOS_REMOTE_HOST=127.0.0.1
PLOS_REMOTE_USER=plos
PLOS_REMOTE_SSH_KEY=/path/to/ssh/key
SSH_STRICT_HOST_KEY_CHECKING=accept-new
# Legacy PROD_* names are still accepted by the server, but new installs should
# prefer the neutral PLOS_REMOTE_* names above.

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=plos
MYSQL_PASSWORD=replace-me
MYSQL_DATABASE=plos

PGSQL_HOST=127.0.0.1
PGSQL_PORT=5432
PGSQL_USER=plos_rag
PGSQL_PASSWORD=replace-me
PGSQL_DATABASE=plos_rag

OLLAMA_HOST=http://127.0.0.1:11434
SCHEMA_REFERENCE_PATH=/path/to/plos/docs/schema-reference.md
PROJECT_ROOT=/path/to/plos
PLOS_REMOTE_PROJECT_ROOT=/path/to/plos
LOG_FILE=/tmp/plos-mcp.log

# Set true when MySQL/PostgreSQL are directly reachable on localhost/LAN.
SKIP_SSH_TUNNEL=true
