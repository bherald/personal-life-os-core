APP_NAME="PLOS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_PUBLIC_URL=http://localhost:8000
APP_HTTP_PORT=8000
VITE_PORT=5173
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:5173
DOCKER_UID=1000
DOCKER_GID=1000
PYTHON_BINARY=python3
PYTHON_REQUIREMENTS=requirements-core.txt
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

# Generate with: php artisan key:generate
WEB_UI_MASTER_PASSWORD=change-me
PLOS_ADMIN_EMAIL=admin@plos.local
# Optional contact email or URL for public-archive API User-Agent strings.
PLOS_USER_AGENT_CONTACT=

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=debug
LOG_DAILY_DAYS=14

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=plos
DB_USERNAME=plos
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-root-me
MYSQL_PORT=3306

RAG_DB_HOST=127.0.0.1
RAG_DB_PORT=5432
RAG_DB_DATABASE=plos_rag
RAG_DB_USERNAME=plos_rag
RAG_DB_PASSWORD=change-me
POSTGRES_PORT=5432

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_LIFETIME=120
# Local only: keep Horizon running but collapse all local queues to one low-priority worker.
HORIZON_LOCAL_THIN=false

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE=default

MAIL_MAILER=log
MAIL_FROM_ADDRESS=plos@example.test
MAIL_FROM_NAME="${APP_NAME}"

FILESYSTEM_DISK=local
FILESYSTEM_MCP_ALLOWED_DIRS=storage/app
PLOS_STORAGE_ROOT=/srv/nextcloud

# Same-host Nextcloud is the preferred full-profile file layer.
# Use NEXTCLOUD_DATA_PATH for fast filesystem-first scans/hashing/extraction.
# WebDAV remains the fallback and compatibility path.
NEXTCLOUD_URL=http://localhost:8080
NEXTCLOUD_USERNAME=plos
NEXTCLOUD_PASSWORD=change-me
NEXTCLOUD_DEFAULT_CALENDAR=plos
NEXTCLOUD_OCC_USER=plos
# Leave blank for minimal installs. Set to /srv/nextcloud/data/{user}/files
# only when the Nextcloud profile or a real mounted data directory exists.
NEXTCLOUD_DATA_PATH=
NEXTCLOUD_JOPLIN_PATH=/Joplin-data
# Optional: Joplin notebook ID for the Watch Later organizer.
JOPLIN_WATCH_LATER_FOLDER_ID=
NEXTCLOUD_LIBRARY_ROOT=/Library
NEXTCLOUD_PORT=8080
NEXTCLOUD_DB_DATABASE=nextcloud
NEXTCLOUD_DB_USERNAME=nextcloud
NEXTCLOUD_DB_PASSWORD=change-me
NEXTCLOUD_DB_ROOT_PASSWORD=change-root-me
# Leave blank to disable optional Windows file organizer integration.
WINDOWS_FILE_HOST=
WINDOWS_FILE_USERNAME=
WINDOWS_FILE_PASSWORD=
WINDOWS_FILE_BASE_PATH=

# Local AI
OLLAMA_API_URL=http://127.0.0.1:11434
OLLAMA_PORT=11434
OLLAMA_SECONDARY_URLS=
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_VISION_MODEL=llava:7b
OLLAMA_TIMEOUT=180
OLLAMA_EMBEDDING_TIMEOUT=30
OLLAMA_TOOL_TIMEOUT=180
OLLAMA_STREAMING_TIMEOUT=240
OLLAMA_CHAT_TIMEOUT=90
# Metadata writeback is intentionally off by default. Enable only after
# reviewing docs/face-metadata-writeback.md and confirming backups/sidecar
# policy for the target media library.
PLOS_METADATA_WRITEBACK_ENABLED=false
PLOS_METADATA_WRITEBACK_IN_PLACE=false
PLOS_LOCAL_COMPUTE_HOST=127.0.0.1
PLOS_LOCAL_COMPUTE_USER=
PLOS_LOCAL_COMPUTE_SCRIPTS_PATH=
# Optional host substring used only when seeding a secondary local Ollama row.
PLOS_SECONDARY_OLLAMA_HOST=
PLOS_SEED_PERSONAL_GENEALOGY_ROOT=false
PLOS_PERSONAL_GENEALOGY_TREE_ID=
PLOS_PERSONAL_GENEALOGY_ROOT_PERSON_ID=
GENEALOGY_HTR_ROOT=/Library/Genealogy
GENEALOGY_HTR_FT_ROOT=/Library/FamilyTree
GENEALOGY_NEXTCLOUD_ROOT=/Library/Genealogy
GENEALOGY_FACE_SYNC_ROOT=/Library/Media
GENEALOGY_FT_REFERENCE_ROOT=/Library/FamilyTree/__intake
GENEALOGY_LEGACY_MEDIA_ROOT=/Library/Media
GENEALOGY_MEDIA_SCAN_ROOTS=/Library/Genealogy,/Library/Media,/Library/Photos,/Library/Pictures,/Library/Documents
GENEALOGY_MEDIA_CONSOLIDATION_BASE=

# Optional private compose override placeholders.
PLOS_PERSONAL_NEXTCLOUD_ROOT=./storage/app/example-nextcloud
PLOS_PERSONAL_NEXTCLOUD_DATA_PATH=/srv/personal/nextcloud/files
PLOS_PERSONAL_JOPLIN_PATH=/Joplin-data
PLOS_PERSONAL_THUNDERBIRD_MCP_URL=http://host.docker.internal:8766
PLOS_PERSONAL_OLLAMA_MODELS=ollama_data

# Optional private source sync for `php artisan dev:setup`.
# Leave blank in public/local installs unless you maintain a separate private source environment.
DEV_SETUP_SOURCE_SSH_HOST=
DEV_SETUP_SOURCE_SSH_USER=
DEV_SETUP_SOURCE_MYSQL_HOST=127.0.0.1
DEV_SETUP_SOURCE_MYSQL_PORT=3306
DEV_SETUP_SOURCE_MYSQL_DATABASE=
DEV_SETUP_SOURCE_MYSQL_USERNAME=
DEV_SETUP_SOURCE_MYSQL_PASSWORD=
DEV_SETUP_SOURCE_RAG_DB_HOST=127.0.0.1
DEV_SETUP_SOURCE_RAG_DB_PORT=5432
DEV_SETUP_SOURCE_RAG_DB_DATABASE=
DEV_SETUP_SOURCE_RAG_DB_USERNAME=
DEV_SETUP_SOURCE_RAG_DB_PASSWORD=

AI_DEFAULT_MODE=auto
AI_USE_DYNAMIC_POOL=true
AI_CACHE_ENABLED=true
AI_SEMANTIC_CACHE=true
AI_CACHE_SIMILARITY=0.85
AI_CACHE_TTL=86400
AI_DEFAULT_MAX_TOKENS=4096
AI_EMBEDDING_CHAR_LIMIT=30000
AI_AGENT_RESPONSE_MAX_CHARS=16000
AI_JOB_OUTPUT_MAX_CHARS=16384

# Optional Claude Code / external model providers. Leave blank for public local-only installs.
CLAUDE_CLI_PATH=claude
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_API_KEY=

# Document extraction and search services
TIKA_URL=http://127.0.0.1:9998
TIKA_PORT=9998
TIKA_TIMEOUT=300
TIKA_MAX_FILE_SIZE=104857600
SEARXNG_URL=http://127.0.0.1:8888
SEARXNG_PUBLIC_URL=http://localhost:8888/
SEARXNG_PORT=8888
SEARXNG_TIMEOUT=30
SEARXNG_CONNECT_TIMEOUT=5
SEARXNG_FAILURE_THRESHOLD=5
SEARXNG_RECOVERY_TIMEOUT=300

# Browser automation / MCP
MCP_DYNAMIC_DISCOVERY_ENABLED=false
MCP_TIMEOUT=60
MCP_LOG_CALLS=true
MCP_CACHE_TTL=3600
MCP_MAX_RETRIES=1
BROWSER_AUTOMATION_TIMEOUT=30
PLOS_SERENA_COMMAND=serena
PLOS_SERENA_PROJECT=
PLOS_SERENA_CONTEXT=ide-assistant
PLOS_SERENA_MODE=editing
PLOS_SERENA_DASHBOARD=false

# Agent runtime defaults
AGENT_SKILLS_PATH=resources/agents/skills
AGENT_MAX_LOOP=10
AGENT_CONTEXT_TOKENS=4000
AGENT_AI_TIMEOUT_SECONDS=45
AGENT_MAX_NESTING=5
AGENT_CONSECUTIVE_TOOL_LIMIT=3
AGENT_CONSECUTIVE_FALLBACK=2
AGENT_AUTO_APPROVE_CONFIDENCE=1.00
AGENT_REVIEW_EXPIRY_DAYS=7
AGENT_HANDOFFS_USE_DATABASE=true
CLAUDE_DEFAULT_MAX=10
CLAUDE_ABSOLUTE_MAX=20
CLAUDE_MIN_CONCURRENT=3
CLAUDE_OLLAMA_FALLBACK_MIN=8

LOCK_TTL_AGENT_SESSION=600
LOCK_TTL_OLLAMA_BUSY=90
LOCK_TTL_FACE_BATCH=600
LOCK_TTL_WHISPER_GPU=900
LOCK_TTL_CLAUDE_SLOT=180
LOCK_TTL_COMPUTE_GPU=300
LOCK_TTL_COMPUTE_CPU=120

# Media, OCR, transcription
FACE_DETECTION_BATCH_SIZE=50
COMPUTE_SSH_USER_DEFAULT=plos
WHISPER_PATH=
WHISPER_MODEL=base
WHISPER_LANGUAGE=
WHISPER_TIMEOUT=300
WHISPER_GPU_LOCK_TTL=900
WHISPER_YOUTUBE_DOWNLOAD_TIMEOUT=120

# Research and scraping safety
SCRAPING_BYPASS_ROBOTS_TXT=false
SCRAPING_SANITIZE_UNTRUSTED_CONTENT=true
TRUST_BOUNDARY_ENABLED=true
TRUST_BOUNDARY_LOG=false
RESEARCH_THROTTLE_MS=500
RESEARCH_SEARCH_DEPTH=3
RESEARCH_MAX_SOURCES=10
RESEARCH_MAX_RESULTS_PER_SOURCE=5
RESEARCH_DATE_FILTER_DAYS=30

# Optional notifications and external APIs
PUSHOVER_API_TOKEN=
PUSHOVER_USER_KEY=
PUSHOVER_API_URL=https://api.pushover.net/1/messages.json
WEATHER_API_KEY=
WEATHER_API_URL=https://api.openweathermap.org/data/2.5
NEWSAPI_KEY=
GNEWS_API_KEY=
NARA_API_KEY=
EUROPEANA_API_KEY=
TRANSKRIBUS_API_KEY=
TWO_CAPTCHA_API_KEY=

# Optional genealogy/search provider credentials
WIKITREE_CLIENT_ID=plos-genealogy
MYHERITAGE_CLIENT_ID=
MYHERITAGE_CLIENT_SECRET=
MYHERITAGE_REDIRECT_URI=http://localhost:8000/auth/myheritage/callback
# Private/personal toggles affect cached Laravel config; run `php artisan config:clear` after changing them.
MYHERITAGE_PERSONAL_AUTOMATION_ENABLED=false
NEWSPAPERS_BARCODE=
NEWSPAPERS_PERSONAL_AUTOMATION_ENABLED=false

# Optional YouTube integration
YOUTUBE_ENABLED=false
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:8000/auth/youtube/callback
YOUTUBE_API_CACHE_TTL=60
YOUTUBE_TRANSCRIPT_STORAGE_ENABLED=true
YOUTUBE_TRANSCRIPT_PREFER_STORED=true
YOUTUBE_TRANSCRIPT_AUTO_STORE=true
YOUTUBE_TRANSCRIPT_ALLOWED_LANGUAGES=en
YOUTUBE_TRANSCRIPT_BATCH_SIZE=3
YOUTUBE_TRANSCRIPT_MAX_RETRIES=3

# Optional desktop/service bridges
THUNDERBIRD_MCP_URL=http://127.0.0.1:8766
THUNDERBIRD_TIMEOUT=30
THUNDERBIRD_CONNECT_TIMEOUT=5
THUNDERBIRD_ARCHIVE_PROFILE_PATH=/Email/Thunderbird
JOPLIN_MAX_CONCURRENT_TESSERACT=3
JOPLIN_RETRY_DELAY=5
JOPLIN_EXTRACTION_VERSION=v2
