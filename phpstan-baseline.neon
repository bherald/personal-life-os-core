			path: app/Services/ScheduledJobService.php

		-
			message: '#^Right side of && is always true\.$#'
			identifier: booleanAnd.rightAlwaysTrue
			count: 1
			path: app/Services/ScheduledJobService.php

		-
			message: '#^Offset ''content'' on array\{name\: string, declared_queue\: string, content\: string\} on left side of \?\? always exists and is not nullable\.$#'
			identifier: nullCoalesce.offset
			count: 1
			path: app/Services/Scheduler/QueuePlacementAuditor.php

		-
			message: '#^Offset ''declared_queue'' on array\{name\: string, declared_queue\: string, content\: string\} on left side of \?\? always exists and is not nullable\.$#'
			identifier: nullCoalesce.offset
